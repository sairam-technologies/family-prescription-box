# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# App URL — local development only (use your Vercel URL in production)
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Required on Vercel (set automatically by sync script)
AUTH_TRUST_HOST="true"

# OpenAI — for prescription AI scanning
OPENAI_API_KEY="sk-..."

# Cloudflare R2 (S3-compatible storage)
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="rxbox-prescriptions"

# Optional: public R2 bucket URL (enable in Cloudflare R2 → bucket → Public access)
# If unset, images are served via /api/files/... (auth required)
# R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
