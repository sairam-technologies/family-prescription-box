generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Family {
  id         String         @id @default(cuid())
  name       String
  inviteCode String         @unique
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  users      User[]
  members    FamilyMember[]
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  isPrimary  Boolean  @default(false)
  isApproved Boolean  @default(false)
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model FamilyMember {
  id              String           @id @default(cuid())
  name            String
  relationship    String?
  dateOfBirth     DateTime?
  familyId        String
  family          Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  prescriptions   Prescription[]
  documents       MemberDocument[]
  medicalReports  MedicalReport[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([familyId])
}

model Prescription {
  id             String         @id @default(cuid())
  familyMemberId String
  familyMember   FamilyMember   @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  imageUrl       String
  imageName      String?
  storageKey     String?
  doctorName     String?
  clinicName     String?
  prescriptionDate DateTime?
  diagnosis      String?
  notes          String?
  rawAiResponse  String?
  scanStatus     ScanStatus     @default(PENDING)
  medicines      Medicine[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([familyMemberId])
  @@index([doctorName])
  @@index([prescriptionDate])
}

model Medicine {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  name           String
  dosage         String?
  frequency      String?
  duration       String?
  instructions   String?
  createdAt      DateTime     @default(now())

  @@index([prescriptionId])
  @@index([name])
}

enum ScanStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentCategory {
  INVOICE
  BILL
  RECEIPT
  INSURANCE
  OTHER
}

enum MedicalReportType {
  LAB
  XRAY
  MRI
  ULTRASOUND
  CT_SCAN
  OTHER
}

enum ReportSeverity {
  LOW
  MODERATE
  HIGH
  CRITICAL
  UNKNOWN
}

enum DoctorUrgency {
  ROUTINE
  SOON
  URGENT
  EMERGENCY
  UNKNOWN
}

model MemberDocument {
  id             String           @id @default(cuid())
  familyMemberId String
  familyMember   FamilyMember     @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  title          String?
  category       DocumentCategory @default(OTHER)
  fileUrl        String
  fileName       String?
  storageKey     String?
  mimeType       String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([familyMemberId])
  @@index([category])
}

model MedicalReport {
  id                     String            @id @default(cuid())
  familyMemberId         String
  familyMember           FamilyMember      @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  title                  String?
  reportType             MedicalReportType @default(OTHER)
  imageUrl               String
  fileName               String?
  storageKey             String?
  scanStatus             ScanStatus        @default(PENDING)
  summary                String?
  findings               String?
  severity               ReportSeverity?
  urgency                DoctorUrgency?
  doctorVisitRecommended Boolean?
  doctorVisitReason      String?
  dietarySuggestions     String?
  lifestyleSuggestions   String?
  rawAiResponse          String?
  reportDate             DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([familyMemberId])
  @@index([reportType])
  @@index([severity])
}
